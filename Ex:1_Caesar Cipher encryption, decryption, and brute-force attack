#include <iostream>
using namespace std;

string enc(string s,int k){
    for(int i=0;i<s.size();i++)
        if(isalpha(s[i])){
            char b=isupper(s[i])?'A':'a';
            s[i]=(s[i]-b+k)%26+b;
        }
    return s;
}

int main(){
    string p;
    int k;
    cout<<"Enter text: ";
    cin>>p;
    cout<<"Enter key: ";
    cin>>k;

    string c=enc(p,k);
    cout<<"Encrypted: "<<c<<endl;
    cout<<"Decrypted: "<<enc(c,26-k)<<endl;

    cout<<"\nBrute Force:\n";
    for(int i=1;i<=25;i++)
        cout<<"Key "<<i<<": "<<enc(c,26-i)<<endl;
}
