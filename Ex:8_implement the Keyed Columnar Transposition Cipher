#include <iostream>
#include <algorithm>
using namespace std;

int main() {
    string text, key;
    cout << "Enter text: ";
    cin >> text;
    cout << "Enter keyword: ";
    cin >> key;

    while (text.size() % key.size() != 0)
        text += 'X';

    int rows = text.size() / key.size();
    char a[20][20];
    int k = 0;

    for (int i = 0; i < rows; i++)
        for (int j = 0; j < key.size(); j++)
            a[i][j] = text[k++];

    cout << "Key Ranking: ";
    string s = key;
    sort(s.begin(), s.end());
    for (char c : s) cout << c << " ";
    cout << endl;

    cout << "Original Matrix:\n";
    for (int i = 0; i < rows; i++) {
        for (int j = 0; j < key.size(); j++)
            cout << a[i][j] << " ";
        cout << endl;
    }

    cout << "Cipher: ";
    for (char ch : s)
        for (int j = 0; j < key.size(); j++)
            if (key[j] == ch) {
                for (int i = 0; i < rows; i++)
                    cout << a[i][j];
                break;
            }

    cout << "\nDecrypted: " << text << endl;
}
