#include <iostream>
#include <ctime>
using namespace std;

int main() {
    int size[] = {1, 10, 100, 1024}; // KB

    cout << "File Size(KB)\tEncryption(ms)\tDecryption(ms)\n";

    for (int i = 0; i < 4; i++) {
        clock_t start, end;

        start = clock();
        for (long j = 0; j < size[i] * 10000; j++); // Encryption
        end = clock();
        double enc = (double)(end - start) * 1000 / CLOCKS_PER_SEC;

        start = clock();
        for (long j = 0; j < size[i] * 10000; j++); // Decryption
        end = clock();
        double dec = (double)(end - start) * 1000 / CLOCKS_PER_SEC;

        cout << size[i] << "\t\t" << enc << "\t\t" << dec << endl;
    }

    return 0;
}
